# _API_KEY: Required for  API calls.
# Portfolio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the Portfolio UI.
API_KEY="API_KEY"

# APP_URL: The URL where this applet is hosted.
# Portfolio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="APP_URL"
